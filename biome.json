{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**",
			"!!**/.pnpm-store",
			"!!**/.mimocode",
			"!!**/.context",
			"!!**/.omo",
			"!!**/.kilo",
			"!!**/.wxt"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noNonNullAssertion": "off"
			},
			"a11y": {
				"useButtonType": "warn",
				"noLabelWithoutControl": "warn",
				"useKeyWithClickEvents": "warn",
				"noStaticElementInteractions": "warn",
				"noAutofocus": "warn",
				"useAriaPropsSupportedByRole": "warn"
			},
			"suspicious": {
				"noExplicitAny": "warn",
				"noArrayIndexKey": "warn",
				"noImplicitAnyLet": "warn",
				"noAssignInExpressions": "warn",
				"noNonNullAssertedOptionalChain": "warn"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
