# 51publisher Backend Configuration

PORT=3001
HOST=127.0.0.1

# Keep this empty in example. Copy to .env and fill in your real OpenAI / DeepSeek / API Key
LLM_API_KEY=your_llm_api_key_here
LLM_ENDPOINT=https://api.deepseek.com/v1

# Optional overrides: if set, these will override client-sent models
# LLM_MODEL=deepseek-chat

# CORS: REQUIRED — fail-closed, server refuses to start if missing or set to '*'.
# Set to your extension's chrome-extension://<id>. Comma-separate dev + prod IDs.
# Find your extension ID in chrome://extensions (toggle developer mode).
# Example (replace with your real IDs):
CORS_ORIGIN=chrome-extension://your-dev-extension-id,chrome-extension://your-prod-extension-id

# JWT Authentication (fail-closed: server refuses to start on weak/placeholder values)
# JWT_SECRET: 32+ char random. Generate:
#   node -e "console.log(require('node:crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-random-secret
# JWT_ADMIN_PASSWORD_HASH: scrypt salt:key. Generate:
#   node packages/backend/scripts/hash-password.mjs
JWT_ADMIN_PASSWORD_HASH=

# SSRF allowlist for production publication targets
# Comma-separated. Supports exact hosts (example.com) and wildcards (*.domain.com).
# Protocol prefix (https://) is optional. Leave empty = fail-closed (deny all).
# ALLOWED_HOSTS=https://dx-999-adm.ympxbys.xyz,https://*.admin.example.com

# Scraper scheduler (acgs51 site adapter). Scheduler only starts when
# LLM_ENDPOINT + LLM_API_KEY are set AND ACGS51_ENABLED=true.
# ACGS51_START_URL:adapter 是单条详情页解析器,必须填具体作品详情页 URL
# (填首页/列表页无效);其 host 须包含在上方 ALLOWED_HOSTS 内。
# ACGS51_ENABLED=true 时启动期强制校验以上两点(fail-closed)。
# ACGS51_START_URL=https://51acgs.com/acg/12345.html
# ACGS51_CRON=0 */6 * * *
# ACGS51_ENABLED=false
