# 51publisher Backend Configuration

PORT=3001
HOST=127.0.0.1

# Keep this empty in example. Copy to .env and fill in your real OpenAI / DeepSeek / API Key
LLM_API_KEY=your_llm_api_key_here
LLM_ENDPOINT=https://api.deepseek.com/v1

# Optional overrides: if set, these will override client-sent models
# LLM_MODEL=deepseek-chat

# CORS: REQUIRED — fail-closed, server refuses to start if missing or set to '*'.
# Set to your extension's chrome-extension://<id>. Comma-separate dev + prod IDs.
# Find your extension ID in chrome://extensions (toggle developer mode).
# Example (replace with your real IDs):
CORS_ORIGIN=chrome-extension://your-dev-extension-id,chrome-extension://your-prod-extension-id

# JWT Authentication (fail-closed: server refuses to start on weak/placeholder values)
# JWT_SECRET: 32+ char random. Generate:
#   node -e "console.log(require('node:crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-random-secret
# JWT_ADMIN_PASSWORD_HASH: scrypt salt:key. Generate:
#   node packages/backend/scripts/hash-password.mjs
JWT_ADMIN_PASSWORD_HASH=

# SSRF allowlist for production publication targets
# Comma-separated. Supports exact hosts (example.com) and wildcards (*.domain.com).
# Protocol prefix (https://) is optional. Leave empty = fail-closed (deny all).
# ALLOWED_HOSTS=https://dx-999-adm.ympxbys.xyz,https://*.admin.example.com

# Scraper scheduler (acgs51 site adapter). Scheduler only starts when
# LLM_ENDPOINT + LLM_API_KEY are set AND ACGS51_ENABLED=true.
# ACGS51_START_URL:adapter 是单条详情页解析器,必须填具体作品详情页 URL
# (填首页/列表页无效);其 host 须包含在上方 ALLOWED_HOSTS 内。
# ACGS51_ENABLED=true 时启动期强制校验以上两点(fail-closed)。
# ACGS51_START_URL=https://51acgs.com/acg/12345.html
# ACGS51_CRON=0 */6 * * *
# ACGS51_ENABLED=false
# ACGS51_LIST_URL: 列表页 URL，填写后启用列表发现模式。host 须在 ALLOWED_HOSTS 内。
# ACGS51_LIST_URL=https://51acgs.com/acg/
# ACGS51_LIST_BUDGET: 每轮 cron 最多处理的新 URL 数（默认 20）
# ACGS51_LIST_BUDGET=20

# Web search enrichment (free DuckDuckGo search, no API key needed)
# 当 ENRICHMENT_ENABLED=true 时，抓取后自动搜索补充资讯（评测/讨论/背景资料）
# ENRICHMENT_ENABLED=false 则跳过富化步骤
ENRICHMENT_ENABLED=true
# 每个作品最多搜索次数（默认 3，范围 1-10，防止触发反爬）
ENRICHMENT_MAX_QUERIES=3

# Quality gate (内容质量门禁)
# 质量分低于此阈值时显示警告（默认 0.6，范围 0-1）
# QUALITY_THRESHOLD=0.6
ENRICHMENT_MAX_QUERIES=3

# Telegram alert channel (one-way push, R26)
# TG_BOT_TOKEN: get from @BotFather. Format: numeric_id:secret (35+ char secret).
# TG_CHAT_ID: your personal chat ID or a group/channel ID (can be negative for groups).
# When TG_ENABLED=true, TG_BOT_TOKEN and TG_CHAT_ID are required (fail-closed).
TG_ENABLED=false
TG_BOT_TOKEN=
TG_CHAT_ID=

# launchd daemon (macOS auto-start, R29a)
# Install: bash scripts/launchd/install.sh   (requires pnpm build:backend first)
# The daemon loads secrets from ~/.51publisher/.env — MUST be chmod 600.
# Create: mkdir -p ~/.51publisher && cp packages/backend/.env.example ~/.51publisher/.env
#         # edit the file, then: chmod 600 ~/.51publisher/.env
# PUBLISHER_ENV_PATH: override the .env path if needed (default: ~/.51publisher/.env)

# Revisit job — periodically checks published posts are still accessible
# REVISIT_ALLOWED_HOSTS: comma-separated hostnames of your self-hosted admin panel.
#   Must NOT contain '*'. Empty = fail-closed (revisit job skips all checks).
#   Must NOT overlap with ALLOWED_HOSTS (scraper targets).
# REVISIT_ALLOWED_HOSTS=https://dx-999-adm.ympxbys.xyz
# REVISIT_IMMEDIATE_CRON: check newly published posts (default: every 5 min)
# REVISIT_IMMEDIATE_CRON=*/5 * * * *
# REVISIT_HEALTH_CRON: re-check all online posts (default: 04:00 daily)
# REVISIT_HEALTH_CRON=0 4 * * *
