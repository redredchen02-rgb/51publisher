{
  "manifest_version": 3,
  "name": "51acgs Scraper",
  "version": "3.0.0",
  "description": "51acgs.com 漫画爬取 + AI 文章生成工具",
  "permissions": [
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "https://51acgs.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/panel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
