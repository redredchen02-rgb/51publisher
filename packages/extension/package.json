{
  "name": "publisher-fill-assistant",
  "description": "51publisher 发帖填充助手 — 只填充、绝不自动提交的 Chrome 扩展",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "check:fixtures": "bash scripts/check-fixture-secrets.sh",
    "check:fixture-drift": "vitest run --config vitest.e2e.config.ts tests/e2e/fixture-contract.test.ts",
    "format": "prettier --write \"**/*.{ts,tsx,css,json,md}\" --ignore-path .gitignore",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@51publisher/shared": "workspace:*",
    "dompurify": "^3.4.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "quill": "2.0.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wxt": "^0.20.26"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
