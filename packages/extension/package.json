{
	"name": "@51guapi/extension",
	"description": "51guapi 吃瓜小幫手 — AI 輔助吃瓜內容產出",
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "wxt",
		"build": "wxt build",
		"zip": "wxt zip",
		"compile": "wxt prepare && tsc --noEmit",
		"test": "vitest run",
		"coverage": "vitest run --coverage",
		"test:watch": "vitest",
		"test:e2e": "vitest run --config vitest.e2e.config.ts",
		"check:fixtures": "bash scripts/check-fixture-secrets.sh",
		"check:fixture-drift": "vitest run --config vitest.e2e.config.ts tests/e2e/fixture-contract.test.ts",
		"postinstall": "wxt prepare || true"
	},
	"dependencies": {
		"@51guapi/shared": "workspace:*",
		"dompurify": "^3.4.10",
		"react": "^19.2.7",
		"react-dom": "^19.2.7"
	},
	"devDependencies": {
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@wxt-dev/module-react": "^1.2.2",
		"jsdom": "^29.1.1",
		"quill": "2.0.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9",
		"wxt": "^0.20.26"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
