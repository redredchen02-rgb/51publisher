{
  "env": {
    "browser": true,
    "es2021": true,
    "webextensions": true,
    "worker": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "error",
    "no-redeclare": "error",
    "eqeqeq": ["warn", "always"],
    "no-constant-condition": "warn",
    "no-empty": ["warn", { "allowEmptyCatch": true }],
    "no-extra-semi": "warn",
    "no-unreachable": "error",
    "no-shadow": "warn",
    "prefer-const": "warn",
    "no-var": "warn",
    "semi": ["warn", "always"],
    "no-mixed-spaces-and-tabs": "warn"
  },
  "globals": {
    "chrome": "readonly",
    "DB": "readonly",
    "LLM": "readonly",
    "Http": "readonly",
    "Parsers": "readonly"
  }
}
