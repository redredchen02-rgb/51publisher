{
  "name": "publisher-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "pnpm install",
    "dev:extension": "pnpm --filter publisher-fill-assistant dev",
    "dev:backend": "pnpm --filter publisher-backend dev",
    "build:extension": "pnpm --filter publisher-fill-assistant build",
    "build:backend": "pnpm --filter publisher-backend build",
    "test": "pnpm -r test",
    "coverage": "pnpm -r --parallel coverage",
    "compile": "pnpm -r compile",
    "lint": "biome check --write",
    "lint:ci": "biome ci .",
    "format": "biome format --write",
    "check": "biome check"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@vitest/coverage-v8": "^4.1.8",
    "prettier": "^3.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  }
}
