{
	"name": "@51publisher/monorepo",
	"private": true,
	"type": "module",
	"scripts": {
		"setup": "pnpm install",
		"dev:extension": "pnpm --filter @51publisher/extension dev",
		"dev:backend": "pnpm --filter @51publisher/backend dev",
		"build:extension": "pnpm --filter @51publisher/extension build",
		"build:backend": "pnpm --filter @51publisher/backend build",
		"test": "pnpm -r test",
		"coverage": "pnpm -r --parallel coverage",
		"compile": "pnpm -r compile",
		"preflight": "tsx --import ./scripts/preflight/wxt-imports-register.mjs scripts/preflight/runner.ts",
		"test:preflight": "vitest run --config vitest.preflight.config.ts",
		"lint": "biome check --write",
		"lint:ci": "biome ci --diagnostic-level=error .",
		"format": "biome format --write",
		"check": "biome check",
		"postinstall": "git config core.hooksPath scripts/git-hooks",
		"eval:golden": "bash scripts/eval-golden.sh"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@vitest/coverage-v8": "^4.1.9",
		"jsdom": "^25.0.1",
		"tsx": "^4.19.2",
		"vitest": "^4.1.9"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"better-sqlite3"
		]
	},
	"version": "0.2.2"
}
