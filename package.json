{
  "name": "publisher-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "pnpm install",
    "dev:extension": "pnpm --filter publisher-fill-assistant dev",
    "dev:backend": "pnpm --filter publisher-backend dev",
    "build:extension": "pnpm --filter publisher-fill-assistant build",
    "build:backend": "pnpm --filter publisher-backend build",
    "test": "pnpm -r test",
    "format": "prettier --write \"**/*.{ts,tsx,css,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  }
}
