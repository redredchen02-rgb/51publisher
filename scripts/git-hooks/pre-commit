#!/usr/bin/env bash
# pre-commit:任何 fixture HTML 变更都必须过脱敏闸门(fail-closed,挡提交)。
# 启用方式(一次性,见 docs/e2e-and-iteration-guide.md):
#   git config core.hooksPath scripts/git-hooks
set -euo pipefail

if git diff --cached --name-only | grep -qE '^tests/e2e/fixtures/.*\.html$'; then
  echo "[pre-commit] fixture 有变更,运行脱敏闸门…"
  bash scripts/check-fixture-secrets.sh || {
    echo "[pre-commit] ✗ 脱敏闸门未通过,已阻止提交。修掉机密后重试。" >&2
    exit 1
  }
fi
